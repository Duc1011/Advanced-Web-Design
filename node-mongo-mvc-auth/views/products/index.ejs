<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><title><%= title %></title></head>
<body>
<div style="float:right">Xin chào, <%= user ? user.username : 'Khách' %> | <a href="/users/logout">Logout</a></div>
<h1><%= title %></h1>
<form method="GET">
  <input name="q" placeholder="Tìm tên..." value="<%= query.q || '' %>">
  <select name="category">
    <option value="">-- Tất cả loại --</option>
    <% categories.forEach(c => { %>
      <option value="<%= c._id %>" <%= query.category==String(c._id) ? 'selected' : '' %>><%= c.name %></option>
    <% }) %>
  </select>
  <select name="sort">
    <option value="">-- Sắp xếp --</option>
    <option value="asc" <%= query.sort=='asc' ? 'selected':'' %>>Giá tăng</option>
    <option value="desc" <%= query.sort=='desc' ? 'selected':'' %>>Giá giảm</option>
  </select>
  <input name="maxPrice" placeholder="Giá tối đa" value="<%= query.maxPrice || '' %>">
  <button type="submit">Áp dụng</button>
</form>

 <!-- Nút qua User -->
    <a href="/users" class="btn btn-outline-primary btn-sm">
      <i class="bi bi-people"></i> Users
    </a>
<p><a href="/products/new">➕ Thêm sản phẩm</a></p>
<table border="1" cellpadding="6" style="width:90%">
  <tr><th>Tên</th><th>Giá</th><th>Loại</th><th>Tồn</th><th>Hành động</th></tr>
  <% products.forEach(p => { %>
    <tr>
      <td><a href="/products/<%= p._id %>"><%= p.name %></a></td>
      <td><%= p.price %></td>
      <td><%= p.categoryId ? p.categoryId.name : 'Không' %></td>
      <td><%= p.stock %></td>
      <td><a href="/products/edit/<%= p._id %>">Sửa</a> | <a href="/products/delete/<%= p._id %>" onclick="return confirm('Xóa?')">Xóa</a></td>
    </tr>
  <% }) %>
</table>
<div style="margin-top:10px">
  <% for(let i=1;i<=totalPages;i++){ %>
    <% if(i===currentPage){ %> <strong><%= i %></strong> <% } else { %> <a href="?page=<%= i %>"><%= i %></a> <% } %>
  <% } %>
</div>
</body></html>
